# Copy this file to .env INSIDE THE TARGET VM ONLY.
# Never commit the real .env file.

# Core service settings
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000

# Provider configuration
MODEL_PROVIDER=<set-provider-name>
MODEL_API_KEY=<set-real-key-inside-vm-only>
MODEL_API_BASE_URL=<optional-provider-endpoint>
MODEL_NAME=<set-model-name>

# Storage / state
DATA_DIR=./data
LOG_LEVEL=info

# Optional connectors
ENABLE_CONNECTORS=false

# Guidance
# Start with the minimum required variables only.
# Do not enable optional integrations until baseline runtime is stable.
